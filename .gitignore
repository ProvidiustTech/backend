# =============================================================================
# Providius — Git Ignore Rules
# =============================================================================

# ── Environment & Secrets ──────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Node.js ────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log
yarn-error.log
pnpm-debug.log
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Python & Virtual Environments ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
ENV/
env/
.env

# ── IDEs & Editors ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Testing ─────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.deepeval
.DeepEval

# ── Next.js ────────────────────────────────────────────────────────────────
.next/
out/
*.tsbuildinfo
.next-env.d.ts

# ── Docker ────────────────────────────────────────────────────────────────
.docker/
docker-compose.override.yml

# ── Database & Cache ──────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
postgres_data/
prometheus_data/
grafana_data/

# ── Logs ───────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db

# ── Uploads & Temp Files ───────────────────────────────────────────────────
uploads/
tmp/
temp/
.tmp/
*.tmp
