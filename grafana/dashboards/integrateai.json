{
  "title": "IntegrateAI Blueprint",
  "uid": "integrateai-blueprint",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "RAG Requests / min",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "rate(integrateai_rag_requests_total[1m]) * 60",
        "legendFormat": "req/min"
      }]
    },
    {
      "id": 2,
      "title": "RAG P95 Latency (s)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(integrateai_rag_latency_seconds_bucket[5m]))",
        "legendFormat": "p95"
      }]
    },
    {
      "id": 3,
      "title": "Avg Hallucination Score",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizValue": 0, "maxVizValue": 1 },
      "targets": [{
        "expr": "integrateai_rag_hallucination_score_sum / integrateai_rag_hallucination_score_count",
        "legendFormat": "score"
      }]
    },
    {
      "id": 4,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "rate(integrateai_rag_requests_total{status='error'}[5m]) / rate(integrateai_rag_requests_total[5m])",
        "legendFormat": "error %"
      }]
    },
    {
      "id": 5,
      "title": "RAG Latency by Node",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(integrateai_rag_latency_seconds_bucket[5m])) by (node)",
        "legendFormat": "{{node}} p95"
      }]
    },
    {
      "id": 6,
      "title": "Chunks Retrieved (avg)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "histogram_quantile(0.5, rate(integrateai_rag_retrieved_chunks_bucket[5m]))",
        "legendFormat": "median chunks"
      }]
    }
  ]
}
