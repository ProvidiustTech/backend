# =============================================================================
# Providius — Environment Configuration
# Copy to .env and fill in your values. Defaults work for local development.
# =============================================================================

# ── Application ────────────────────────────────────────────────────────────
APP_NAME=Providius
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production-min32ch-very-long-key-here
LOG_LEVEL=INFO
LOG_FORMAT=console

# ── Database (PostgreSQL + pgvector) ───────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=integrateai
POSTGRES_PASSWORD=integrateai_secret
POSTGRES_DB=integrateai_db
DATABASE_URL=postgresql+asyncpg://integrateai:integrateai_secret@postgres:5432/integrateai_db

# ── LLM Provider Selection (openai|anthropic|groq|ollama) ──────────────────
LLM_PROVIDER=ollama

# ── OpenAI Configuration ───────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Anthropic Configuration ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Groq Configuration ────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# ── Ollama Configuration (local, free, no API key) ────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
EMBEDDING_DIM=768

# ── Cohere Reranking ──────────────────────────────────────────────────────
COHERE_API_KEY=
RERANK_MODEL=rerank-english-v3.0
RERANK_TOP_N=5

# ── JWT Authentication ────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-jwt-secret-change-in-production-min32ch-very-long-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_CHAT_PER_MINUTE=20

# ── RAG Configuration ─────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVE=10
TOP_K_FINAL=5
SIMILARITY_THRESHOLD=0.7
ENABLE_HYBRID_SEARCH=true

# ── Monitoring & Observability ────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ── Grafana Dashboard ─────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=integrateai_grafana
GRAFANA_PORT=3000

# ── Frontend Configuration ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Providius
NEXT_PUBLIC_ENVIRONMENT=development
